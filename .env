PROJECT_NAME=aero-maestro
SERVER_IP= 192.168.2.14 #ip hosting the service e.g. 10.10.4.4
SERVER_BASE_PATH=/home/ubuntu/data

# UI
UI_IP=${SERVER_IP}
UI_PORT=8080

# Backend
BACKEND_IP=${SERVER_IP}
BACKEND_PORT=8080
BACKEND_KUBERNETES_PROVIDER_ENABLE="true"
KUBERNETES_RESOURCES_ENABLE=false #true

# Swagger
SPRINGDOC_API_DOCS_ENABLED="true"
SPRINGDOC_API_SWAGGER_UI_ENABLED="true"
SPRINGDOC_API_DOCS_PATH="/api/openapi"
SPRINGDOC_API_SWAGGER_UI_PATH="/api/swagger"

# Database
DATABASE_IP=${SERVER_IP}
DATABASE_PORT=3306
DATABASE_NAME=orchestrator
DATABASE_ROOT_PASSWORD=!r00t!
DATABASE_VOLUME_PATH=${SERVER_BASE_PATH}/database/data

# Phpmyadmin
PHPMYADMIN_PORT=8010

# knative serverless controller
QUARKUS_HTTP_PORT=9500
MAESTRO_REST_API_URL=http://localhost:${BACKEND_PORT}/
